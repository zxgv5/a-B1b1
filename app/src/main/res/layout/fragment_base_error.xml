<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/view_error"
    android:background="?attr/backgroundColor"
    android:clickable="true"
    android:focusable="true"
    android:descendantFocusability="afterDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/image_error"
        android:layout_width="@dimen/px400"
        android:layout_height="@dimen/px250"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.48"
        app:srcCompat="@drawable/net_error"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px30"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/text_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/px30"
        android:text="@string/net_error"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_error"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="@dimen/px30"
        android:gravity="center"
        android:id="@+id/button_retry"
        android:background="@drawable/button_common"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/px90"
        android:layout_marginTop="@dimen/px30"
        android:text="@string/retry"
        android:paddingStart="@dimen/px50"
        android:paddingEnd="@dimen/px50"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_error"/>
</androidx.constraintlayout.widget.ConstraintLayout>
